<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>Rover</AssemblyName>
    <RootNamespace>Rover</RootNamespace>
    <Company>Acor</Company>
    <AssemblyTitle>Rover</AssemblyTitle>
    <Product>Rover</Product>
    <Description>Bulk tool remapping for CID, BPP, and common G-code files.</Description>
    <ApplicationIcon>Resources\app.ico</ApplicationIcon>
    <!-- Prevent SDK default globs from compiling helper/temp projects left under this folder -->
    <DefaultItemExcludes>$(DefaultItemExcludes);SmokeHarness\**\*;Tools\**\*</DefaultItemExcludes>
  </PropertyGroup>
</Project>
